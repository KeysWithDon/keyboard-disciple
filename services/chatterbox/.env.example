CHATTERBOX_SERVICE_TOKEN=replace-with-a-long-random-secret
CHATTERBOX_ALLOW_UNAUTHENTICATED=false
CHATTERBOX_DEVICE=auto
CHATTERBOX_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CHATTERBOX_VOICE_ROOT=/app/voices
CHATTERBOX_VOICE_MANIFEST=/app/voices/voices.json
CHATTERBOX_MAX_TEXT_LENGTH=300
CHATTERBOX_RATE_LIMIT_REQUESTS=30
CHATTERBOX_RATE_LIMIT_WINDOW_SECONDS=60
CHATTERBOX_CACHE_TTL_SECONDS=1800
CHATTERBOX_CACHE_MAX_ENTRIES=256
